---
const groups = [
	{
		label: 'Protect',
		title: 'Lock down what you already have',
		items: [
			'Phones, laptops, and tablets set up securely',
			'Home Wi-Fi, router, and smart devices',
			'Passwords, two-factor, and breach monitoring',
			'Privacy cleanup and data-broker removal',
		],
	},
	{
		label: 'Recover',
		title: 'Handle the worst case, calmly',
		items: [
			'Rapid triage when you’ve been compromised',
			'Account and identity recovery',
			'Scam, fraud, and phishing response',
			'Stalkerware and unwanted-tracking checks',
		],
	},
	{
		label: 'Stay ahead',
		title: 'Keep up as threats change',
		items: [
			'AI scam and deepfake defense',
			'Training for you, your family, or your team',
			'Small business security and privacy compliance',
			'Ongoing advisory and regular check-ins',
		],
	},
];
---

<section id="services">
	<div class="shell">
		<div class="section-head">
			<h2>What we actually help with.</h2>
			<p>Start with a one-off assessment or stay on for ongoing support. The work falls into three areas.</p>
		</div>
		<div class="grid">
			{
				groups.map((group) => (
					<article class="group">
						<span class="label">{group.label}</span>
						<h3>{group.title}</h3>
						<ul>
							{group.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.group {
		padding: 32px;
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
	}

	.label {
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--red);
	}

	.group h3 {
		margin-top: 14px;
		font-size: 21px;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.group ul {
		margin-top: 22px;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.group li {
		position: relative;
		padding-left: 22px;
		font-size: 15px;
		color: var(--muted);
	}

	.group li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 9px;
		width: 6px;
		height: 6px;
		border-radius: 1px;
		background: var(--ink);
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
