---
const checks = [
	'Your accounts, passwords, and logins',
	'Your phones, laptops, and devices',
	'Your home or office network',
	'What strangers can find about you online',
	'Your family or your team',
];
---

<section class="hero">
	<div class="shell">
		<article class="brief">
			<div class="brief-body">
				<div class="brief-main">
					<h1 class="reveal" style="--i: 0">Cybersecurity help for <mark class="hl">real people</mark>.</h1>
					<p class="brief-lede reveal" style="--i: 1">
						DIHAX helps individuals, families, high-profile figures, and small businesses find the
						gaps a real attacker would use, close them in plain steps, and know exactly what to do
						if something goes wrong.
					</p>
					<div class="brief-actions reveal" style="--i: 2">
						<a href="/#contact" class="btn btn-primary">Book a free first call</a>
						<a href="/#process" class="btn btn-secondary">See how it works</a>
					</div>
				</div>
				<aside class="brief-scope reveal" style="--i: 2">
					<p class="scope-label"><mark>What we review</mark></p>
					<ul>
						{checks.map((item) => <li>{item}</li>)}
						<li class="more">and more, tailored to you</li>
					</ul>
				</aside>
			</div>
		</article>
	</div>
</section>

<style>
	.hero {
		padding: 52px 0 96px;
	}

	.brief {
		background: var(--panel);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.brief-body {
		display: grid;
		grid-template-columns: 1.35fr 0.85fr;
	}

	.brief-main {
		padding: 60px 52px;
		border-right: 1px solid var(--line);
	}

	h1 {
		font-size: clamp(38px, 5.4vw, 62px);
		line-height: 1.03;
		letter-spacing: -0.025em;
		max-width: 16ch;
	}

	.hl {
		color: var(--ink);
		background-color: transparent;
		background-image: linear-gradient(rgba(213, 43, 30, 0.18), rgba(213, 43, 30, 0.18));
		background-repeat: no-repeat;
		background-position: 0 center;
		background-size: 0% 86%;
		border-radius: 3px;
		padding: 0 0.1em;
		margin: 0 -0.05em;
		box-decoration-break: clone;
		-webkit-box-decoration-break: clone;
		animation: highlight 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
		animation-delay: 0.8s;
	}

	@keyframes highlight {
		to {
			background-size: 100% 86%;
		}
	}

	.brief-lede {
		margin-top: 26px;
		font-size: 19px;
		color: var(--muted);
		max-width: 50ch;
	}

	.brief-actions {
		margin-top: 34px;
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
	}

	.brief-scope {
		padding: 44px 40px;
		background: var(--bg);
		display: flex;
		flex-direction: column;
	}

	.scope-label {
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.scope-label mark {
		background: rgba(213, 43, 30, 0.16);
		color: var(--ink);
		padding: 3px 8px;
		border-radius: 3px;
	}

	.brief-scope ul {
		margin-top: 12px;
		list-style: none;
	}

	.brief-scope li {
		display: flex;
		align-items: center;
		gap: 13px;
		padding: 15px 0;
		font-size: 15px;
		border-bottom: 1px solid var(--line);
	}

	.brief-scope li:last-child {
		border-bottom: none;
	}

	.brief-scope li.more {
		color: var(--muted);
		font-family: var(--mono);
		font-size: 13px;
	}

	.brief-scope li.more::before {
		content: '+';
		width: auto;
		height: auto;
		background: transparent;
		color: var(--red);
		font-weight: 600;
		font-size: 15px;
		line-height: 1;
	}

	.brief-scope li::before {
		content: '';
		width: 6px;
		height: 6px;
		flex-shrink: 0;
		background: var(--ink);
	}

	.hero .reveal {
		animation-delay: calc(var(--i, 0) * 90ms);
	}

	@media (prefers-reduced-motion: reduce) {
		.hl {
			background-size: 100% 86%;
			animation: none;
		}
	}

	@media (max-width: 900px) {
		.brief-body {
			grid-template-columns: 1fr;
		}

		.brief-main {
			padding: 44px 32px;
			border-right: none;
			border-bottom: 1px solid var(--line);
		}

		.brief-scope {
			padding: 36px 32px;
		}

		h1 {
			max-width: none;
		}
	}

	@media (max-width: 520px) {
		.hero {
			padding: 32px 0 64px;
		}

		.brief-main {
			padding: 36px 24px;
		}

		.brief-lede {
			font-size: 17px;
		}
	}
</style>
