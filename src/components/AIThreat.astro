---
const threats = [
	{
		title: 'Voice cloning & fake emergencies',
		body: 'A call in your child or your CEO’s voice begging for money. We set up family safe-words and verification habits that beat the scam.',
	},
	{
		title: 'Deepfakes & impersonation',
		body: 'Fake videos, images and accounts pretending to be you. We help you detect, monitor for, and take down AI impersonation.',
	},
	{
		title: 'Hyper-personalized scams',
		body: 'AI writes flawless, tailored phishing using your own public data. We show you and your team how to spot what used to be obvious.',
	},
	{
		title: 'Your data inside AI tools',
		body: 'Everything you paste into a chatbot can leak or be retained. We help you use AI productively without giving away your secrets.',
	},
];
---

<section id="ai" class="ai">
	<div class="shell">
		<div class="ai-inner">
			<div class="ai-copy">
				<p class="eyebrow">The new threat</p>
				<h2>AI made every scam <span class="accent-text">personal.</span></h2>
				<p>
					This is the biggest shift in personal security in a decade. Attackers now clone voices,
					fake faces, and write flawless scams aimed at you and the people you love. We explain
					these risks in plain language and help you build simple habits that defeat them.
				</p>
				<a href="/#contact" class="btn btn-light">Get an AI risk briefing</a>
			</div>
			<div class="ai-grid">
				{
					threats.map((t) => (
						<article class="threat">
							<h3>{t.title}</h3>
							<p>{t.body}</p>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.ai {
		background: var(--ink);
		color: #fff;
	}

	.ai-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 64px;
		align-items: start;
	}

	.ai .eyebrow {
		color: var(--red);
	}

	.ai-copy h2 {
		font-size: clamp(28px, 4vw, 40px);
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.ai-copy p {
		margin: 20px 0 32px;
		font-size: 18px;
		color: rgba(255, 255, 255, 0.7);
	}

	.ai-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.threat {
		padding: 24px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.03);
	}

	.threat h3 {
		font-size: 17px;
		font-weight: 600;
	}

	.threat p {
		margin-top: 10px;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.65);
	}

	@media (max-width: 900px) {
		.ai-inner {
			grid-template-columns: 1fr;
			gap: 40px;
		}
	}

	@media (max-width: 520px) {
		.ai-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
