---
const steps = [
	{
		when: 'First',
		title: 'We talk',
		body: 'A confidential conversation about your life, your worries, and who might realistically target you and how.',
	},
	{
		when: 'Next',
		title: 'You get a plan',
		body: 'A clear, prioritized report written for you: what to fix first, what can wait, and exactly how to do it.',
	},
	{
		when: 'Then',
		title: 'We set it up',
		body: 'We walk you, your family, or your team through the changes and the habits that keep you safe day to day.',
	},
	{
		when: 'Ongoing',
		title: 'We stay reachable',
		body: 'Stay protected as threats change, with check-ins and someone to message the moment something feels wrong.',
	},
];
---

<section id="process" class="process">
	<div class="shell">
		<div class="section-head">
			<h2>What working with us looks like.</h2>
		</div>
		<ol class="steps">
			{
				steps.map((step) => (
					<li class="step">
						<span class="when">{step.when}</span>
						<h3>{step.title}</h3>
						<p>{step.body}</p>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.process {
		background: var(--bg-soft);
	}

	.steps {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 28px;
	}

	.step {
		display: flex;
		flex-direction: column;
	}

	.when {
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--red);
	}

	.step h3 {
		margin-top: 14px;
		font-size: 21px;
		font-weight: 600;
	}

	.step p {
		margin-top: 12px;
		font-size: 15px;
		color: var(--muted);
	}

	@media (max-width: 900px) {
		.steps {
			grid-template-columns: 1fr 1fr;
			gap: 32px;
		}
	}

	@media (max-width: 520px) {
		.steps {
			grid-template-columns: 1fr;
		}
	}
</style>
