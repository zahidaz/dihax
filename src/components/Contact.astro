---
const email = 'contact@dihax.com';
---

<section id="contact" class="contact">
	<div class="shell contact-inner">
		<p class="eyebrow">Get in touch</p>
		<h2>Start with a conversation.</h2>
		<p class="lede">
			Tell us what’s on your mind. The first call is free, there’s no pressure, and nothing
			leaves the conversation. Most enquiries get a reply within one business day.
		</p>
		<a href={`mailto:${email}`} class="email">{email}</a>
		<div class="assurance">
			<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="3" y="11" width="18" height="11" rx="2" />
				<path d="M7 11V7a5 5 0 0 1 10 0v4" />
			</svg>
			<p>
				<strong>We’ll never ask for your passwords or financial details.</strong>
				For anything sensitive, we can set up a secure channel.
			</p>
		</div>
	</div>
</section>

<style>
	.contact {
		background: var(--bg-soft);
		border-top: 1px solid var(--line);
	}

	.contact-inner {
		max-width: 720px;
		text-align: center;
		margin-inline: auto;
	}

	h2 {
		font-size: clamp(30px, 4.2vw, 46px);
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 18px auto 0;
		max-width: 560px;
		font-size: 19px;
		color: var(--muted);
	}

	.email {
		display: inline-block;
		margin-top: 32px;
		font-family: var(--mono);
		font-size: clamp(22px, 3.5vw, 30px);
		text-decoration: none;
		color: var(--ink);
		border-bottom: 2px solid var(--ink);
		padding-bottom: 4px;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.email:hover {
		color: var(--red);
		border-color: var(--red);
	}

	.assurance {
		margin: 44px auto 0;
		max-width: 560px;
		display: flex;
		align-items: center;
		gap: 16px;
		text-align: left;
		padding: 20px 24px;
		background: var(--panel);
		border: 1px solid var(--line);
		border-radius: var(--radius);
	}

	.assurance svg {
		flex-shrink: 0;
		color: var(--red);
	}

	.assurance p {
		font-size: 15px;
		color: var(--muted);
		line-height: 1.5;
	}

	.assurance strong {
		display: block;
		font-weight: 600;
		color: var(--ink);
		margin-bottom: 2px;
	}

	@media (max-width: 520px) {
		.assurance {
			flex-direction: column;
			text-align: center;
			align-items: center;
		}
	}
</style>
